name = "XiaoChenxu/msdoc-viewer"

version = "0.1.1"

preferred_target = "js"

license = "Apache-2.0"

readme = "README.md"

repository = "https://github.com/XiaoChenxu1001/msdoc-viewer-moonbit"

keywords = [
  "ms-doc",
  "parser",
  "renderer",
  "word-document",
  "document-processing",
  "wasm",
  "multi-target"
]

description = "High-performance MS-DOC (.doc binary Word) parser and renderer for MoonBit, supporting JS, WASM, and WASM-GC backends with Web Worker support"
